{
  "name": "linux-do-it",
  "version": "1.0.0",
  "type": "module",
  "description": "Linux Do It — enhanced Linux.do reading experience with card views, Reader, and side panel search.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/galaxypluto/linux-do-it.git"
  },
  "bugs": "https://github.com/galaxypluto/linux-do-it/issues",
  "homepage": "https://github.com/galaxypluto/linux-do-it#readme",
  "scripts": {
    "icons": "node scripts/generate-icons.mjs",
    "dev": "pnpm icons && wxt",
    "build": "pnpm icons && wxt build",
    "zip": "wxt zip",
    "prepare:wxt": "wxt prepare",
    "typecheck": "wxt prepare && tsc --noEmit",
    "test": "wxt prepare && vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "check": "pnpm typecheck && pnpm test && pnpm build && pnpm e2e"
  },
  "dependencies": {
    "@wxt-dev/module-react": "1.2.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@resvg/resvg-js": "2.6.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/chrome": "0.1.42",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "jsdom": "29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "6.0.3",
    "vitest": "4.1.7",
    "wxt": "0.20.26"
  },
  "packageManager": "pnpm@9.15.9"
}
